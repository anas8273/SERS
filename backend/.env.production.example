# -----------------------------------------------------------------
# SERS: Production Environment Configuration Template
# -----------------------------------------------------------------
# Copy this file to .env and update ALL values before deploying!
# DO NOT commit the actual .env file to git.
# -----------------------------------------------------------------

APP_NAME="SERS"
APP_ENV=production
APP_KEY=                           # ← Run: php artisan key:generate
APP_DEBUG=false                    # ← CRITICAL: Must be false in production!
APP_URL=https://api.your-domain.com
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------
# FRONTEND URL (مهم لإعدادات CORS والأمان)
# -----------------------------------------------------------------
FRONTEND_URL=https://your-domain.com

# -----------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                  # ← Less noisy in production

# -----------------------------------------------------------------
# DATABASE CONNECTION
# -----------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sers_db
DB_USERNAME=sers_user              # ← Never use 'root' in production!
DB_PASSWORD=STRONG_PASSWORD_HERE   # ← REQUIRED: Set a strong password

# -----------------------------------------------------------------
# DRIVERS (Production-optimized)
# -----------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file                  # ← Consider Redis for high traffic
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database          # ← Use 'database' or 'redis' (NOT 'sync')
SESSION_DRIVER=file
SESSION_LIFETIME=120

# -----------------------------------------------------------------
# SEARCH ENGINE
# -----------------------------------------------------------------
SCOUT_DRIVER=database

# -----------------------------------------------------------------
# FIREBASE CONFIGURATION
# -----------------------------------------------------------------
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json
FIREBASE_PROJECT_ID=sers-project-10ba4

# -----------------------------------------------------------------
# SANCTUM (For SPA authentication)
# -----------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=your-domain.com,www.your-domain.com

# -----------------------------------------------------------------
# STRIPE (LIVE KEYS — Replace test keys!)
# -----------------------------------------------------------------
STRIPE_KEY=pk_live_XXXXXX
STRIPE_SECRET=sk_live_XXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXX  # ← From Stripe Dashboard > Webhooks

# -----------------------------------------------------------------
# MAIL (SMTP — Required for order/welcome/withdrawal emails)
# -----------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=noreply@your-domain.com
MAIL_PASSWORD=YOUR_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------
# AI Services (Groq)
# -----------------------------------------------------------------
GROQ_API_KEY="gsk_XXXXXX"
OPENAI_API_KEY="${GROQ_API_KEY}"
OPENAI_BASE_URL="https://api.groq.com/openai/v1"
OPENAI_MODEL="llama-3.3-70b-versatile"

# -----------------------------------------------------------------
# PRODUCTION DEPLOYMENT CHECKLIST:
# -----------------------------------------------------------------
# 1. php artisan key:generate
# 2. php artisan migrate --force
# 3. php artisan config:cache
# 4. php artisan route:cache
# 5. php artisan view:cache
# 6. php artisan optimize
# 7. Set up cron: * * * * * cd /path && php artisan schedule:run >> /dev/null 2>&1
# 8. Start queue worker: php artisan queue:work --sleep=3 --tries=3
# 9. Configure Stripe webhook in Dashboard: https://your-domain.com/api/webhooks/stripe
# 10. Verify FRONTEND_URL matches your actual frontend domain
# -----------------------------------------------------------------
