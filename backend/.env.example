# -----------------------------------------------------------------
# SERS: Smart Educational Records System — Environment Configuration
# IMPORTANT: Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to version control — only `.env.example`.
# -----------------------------------------------------------------

APP_NAME="SERS"
APP_ENV=local
# Generate with: php artisan key:generate
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8001
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------
# FRONTEND URL (Required for CORS and security headers)
# -----------------------------------------------------------------
FRONTEND_URL=http://localhost:3001

# -----------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Use 'debug' in local, 'warning' in production
LOG_LEVEL=debug

# -----------------------------------------------------------------
# DATABASE CONNECTION (MySQL)
# -----------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sers_db
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# -----------------------------------------------------------------
# DRIVERS (Optimized for Local — change CACHE/QUEUE for production)
# -----------------------------------------------------------------
BROADCAST_DRIVER=log
# Options: file, redis, database
CACHE_DRIVER=file
FILESYSTEM_DISK=public
# Options: sync, database, redis (use 'redis' in production for PDF/AI jobs)
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# -----------------------------------------------------------------
# SEARCH ENGINE
# -----------------------------------------------------------------
SCOUT_DRIVER=database

# -----------------------------------------------------------------
# FIREBASE CONFIGURATION
# Get service account JSON from: Firebase Console → Project Settings → Service Accounts
# Save as: backend/storage/app/firebase/service-account.json
# -----------------------------------------------------------------
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# -----------------------------------------------------------------
# SANCTUM (SPA Authentication)
# Add your frontend domain(s) here (comma-separated, no trailing slash)
# -----------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001,127.0.0.1:3000,127.0.0.1:3001

# -----------------------------------------------------------------
# STRIPE (Payments)
# Get keys from: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------
STRIPE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# -----------------------------------------------------------------
# MAIL
# -----------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sers.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------
# AI SERVICES (Groq — Default Provider)
# Get API key from: https://console.groq.com/keys
# -----------------------------------------------------------------
GROQ_API_KEY=gsk_your_groq_api_key_here
OPENAI_API_KEY="${GROQ_API_KEY}"
OPENAI_BASE_URL="https://api.groq.com/openai/v1"
OPENAI_MODEL="llama-3.3-70b-versatile"
