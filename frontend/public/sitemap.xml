<?xml version="1.0" encoding="UTF-8"?>
<!--
  SERS Sitemap — Static Pages
  NOTE: Dynamic template pages are fetched via Next.js sitemap.ts (if created)
  For production: replace https://your-domain.com with your actual domain
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <!-- Home -->
  <url>
    <loc>https://your-domain.com/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Template Store -->
  <url>
    <loc>https://your-domain.com/marketplace</loc>
    <changefreq>daily</changefreq>
    <priority>0.95</priority>
  </url>

  <!-- Educational Services -->
  <url>
    <loc>https://your-domain.com/services</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- About -->
  <url>
    <loc>https://your-domain.com/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- Contact -->
  <url>
    <loc>https://your-domain.com/contact</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- FAQ -->
  <url>
    <loc>https://your-domain.com/faq</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- Privacy Policy -->
  <url>
    <loc>https://your-domain.com/privacy</loc>
    <changefreq>yearly</changefreq>
    <priority>0.4</priority>
  </url>

  <!-- Terms -->
  <url>
    <loc>https://your-domain.com/terms</loc>
    <changefreq>yearly</changefreq>
    <priority>0.4</priority>
  </url>

  <!-- Auth pages — low priority, these don't need indexing -->
  <url>
    <loc>https://your-domain.com/login</loc>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>

  <url>
    <loc>https://your-domain.com/register</loc>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>

</urlset>
