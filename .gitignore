# SERS/.gitignore

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- Dependencies ---
node_modules/
vendor/

# --- Environment secrets ---
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local

# --- Firebase secrets ---
**/firebase-service-account.json
**/service-account.json
storage/app/firebase/

# --- Build artifacts ---
.next/
build/
dist/
public/build
public/hot
tsconfig.tsbuildinfo

# --- Logs & output ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*_output.txt
*_output*.txt

# --- Test & cache ---
.phpunit.result.cache
.phpunit.cache/
*.result.cache

# --- Binaries ---
*.exe
*.dll

# --- Database (local dev) ---
*.sqlite
*.sqlite-journal

# --- Temporary fix scripts ---
fix-*.js
rtl-*.js
*-batch.js
*-final.js
*-complete.js
*-remaining.js
translate_*.js
list-all-*.js
find-*.js
remaining-critical.txt

# --- Archive (cleanup) ---
_archive/